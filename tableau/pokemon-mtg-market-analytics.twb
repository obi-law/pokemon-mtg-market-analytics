      <aliases enabled='yes' />
      <column caption='Tier Group' datatype='string' name='[Calculation_1403276400123907]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tier_mapped] = &apos;top&apos; &#13;&#10;    THEN &apos;top&apos; &#13;&#10;    ELSE &apos;other&apos; &#13;&#10;END' />
        <aliases>
          <alias key='&quot;other&quot;' value='all other tiers' />
          <alias key='&quot;top&quot;' value='chase tier' />
        </aliases>
      </column>
      <column caption='Conc Color' datatype='string' name='[Calculation_1403276400222212]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER([game]) = LOWER([Parameters].[Parameter 1]) &#13;&#10;    THEN [game] + &apos;-&apos; + [Calculation_1403276400123907] &#13;&#10;    ELSE &apos;inactive-&apos; + [Calculation_1403276400123907] &#13;&#10;END' />
      </column>
      <column caption='Is Active Game' datatype='boolean' name='[Calculation_1403276400328709]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LOWER([game]) = LOWER([Parameters].[Parameter 1])' />
      </column>
      <column caption='Emphasis' datatype='string' name='[Calculation_1403276403179527]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER([game]) = LOWER([Parameters].[Parameter 1])&#13;&#10;    THEN [game] &#13;&#10;    ELSE &quot;inactive&quot; &#13;&#10;END' />
      </column>
      <column caption='Tier Cards' datatype='integer' name='[Calculation_1550611634446336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([card_key])' />
      </column>
      <column caption='Tier Total $' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_1550611634528257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price_usd])' />
      </column>
      <column caption='Tier Label' datatype='string' name='[Calculation_1550611639537666]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1403276400123907] = &apos;top&apos; &#13;&#10;    THEN (IF [game] = &apos;mtg&apos; &#13;&#10;            THEN &apos;chase tier (mythic)&apos; &#13;&#10;            ELSE &apos;chase tier (illustration rare &amp; up)&apos;&#13;&#10;          END) &#13;&#10;    ELSE &apos;all other tiers (common–rare)&apos; &#13;&#10;END' />
      </column>
      <column caption='Pct of Game Value' datatype='real' default-format='p0.0%' name='[Calculation_2013505628016641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price_usd]) &#13;&#10;/ &#13;&#10;SUM(&#13;&#10;    { FIXED [game] : SUM([price_usd]) }&#13;&#10;)' />
      </column>
